# ============================================
# GharSathi Frontend Environment Variables
# ============================================

# Backend API URL (for production)
# VITE_API_URL=http://localhost:5000

# --------------------------------------------
# DEMO MODE — Academic Presentation Only
# --------------------------------------------
# When set to true, a "Login as Super Admin (Demo)" button appears on the
# Login page. It uses the real auth API — no token is hardcoded.
# Set to false or remove before production deployment.
VITE_DEMO_MODE=true
