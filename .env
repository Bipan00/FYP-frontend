# ============================================
# GharSathi Frontend Environment Variables
# ============================================

# Google Maps API Key (Feature 8)
# Get this from Google Cloud Console: https://console.cloud.google.com/
# Enable "Maps JavaScript API" and "Geocoding API" (optional)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here (Not required for Leaflet)

# Backend API URL (for production)
# VITE_API_URL=http://localhost:5000
